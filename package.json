{
  "name": "langtu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "collect:bible-kids": "node ./scripts/collect-bible-by-kids.mjs",
    "build:book3-vocab-graph": "node ./scripts/build-book3-a1-c2-vocab-graph.mjs",
    "web:prepare": "node ./scripts/copy-web.mjs",
    "web:serve": "node ./scripts/serve-web.mjs",
    "android:ensure-sdk": "node ./scripts/ensure-android-sdk.mjs",
    "android:sync": "npm run web:prepare && npx cap sync",
    "android:copy": "npm run web:prepare && npx cap copy",
    "android:open": "npx cap open android",
    "android:assemble": "npm run web:prepare && npx cap sync && npm run android:ensure-sdk && cd android && ./gradlew assembleDebug",
    "android:clean": "npx cap clean"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
